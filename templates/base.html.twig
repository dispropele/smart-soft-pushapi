<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Ломбард{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    {{ importmap() }}
</head>
<body class="bg-[#f8fbfd] text-[#333] flex flex-col min-h-screen font-sans">

    {# Строгая синяя шапка #}
    <header class="bg-gradient-to-r from-[#1d4e75] to-[#2d6ca2] shadow-md">
        <div class="max-w-[1400px] mx-auto px-4 py-4 flex items-center justify-between gap-6">
            
            {# Логотип #}
            <a href="{{ path('app_catalog') }}" class="flex items-baseline gap-2 shrink-0">
                <span class="text-2xl font-bold text-white tracking-tight">ЛОМБАРД</span>
            </a>

            {# Поиск #}
            <form method="get" action="{{ path('app_catalog') }}" class="flex-1 max-w-[500px] relative hidden md:block">
                <input type="text" name="q" value="{{ app.request.query.get('q', '') }}" placeholder="Поиск товаров..."
                       class="w-full bg-white/10 border border-white/20 rounded-[3px] px-4 py-2 text-sm text-white placeholder-white/60 focus:bg-white focus:text-[#333] focus:outline-none transition">
            </form>

            <div class="flex items-center gap-5 text-sm font-medium">
                <a href="/admin" class="text-white/80 hover:text-white transition">Администратору</a>
                
                {% if app.session.get('client_id') %}
                    <a href="{{ path('app_client_cabinet') }}" class="text-white/80 hover:text-white transition">Кабинет</a>
                {% else %}
                    <a href="{{ path('app_client_login') }}" class="text-white/80 hover:text-white transition">Вход</a>
                {% endif %}

                {# КОРЗИНА СКРЫТА #}
                {# 
                <a href="{{ path('app_cart') }}" class="bg-[#60b060] text-white px-4 py-2 rounded-[3px] hover:bg-[#529a52] transition">
                    Корзина
                </a> 
                #}
            </div>
        </div>
    </header>

    {# Сообщения #}
    <div class="max-w-[1400px] w-full mx-auto px-4 py-4">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 rounded-[3px] border px-4 py-3 {% if label == 'success' %}border-[#c3e6cb] bg-[#d4edda] text-[#155724]{% elseif label == 'danger' or label == 'error' %}border-[#f5c6cb] bg-[#f8d7da] text-[#721c24]{% else %}border-[#d6d8db] bg-[#e2e3e5] text-[#383d41]{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {# Контентная часть #}
    <main class="max-w-[1400px] w-full mx-auto px-4 py-8 flex-grow">
        {% block body %}{% endblock %}
    </main>

    {# Футер #}
    <footer class="mt-auto py-6 bg-[#e1f0f5] border-t border-[#dce8f0] text-center text-sm text-[#7a9fb5]">
        <div class="max-w-[1400px] mx-auto px-4">
            <p>© {{ "now"|date("Y") }} Ломбард. Все права защищены.</p>
        </div>
    </footer>

    {# Load app entrypoint (Stimulus, CSRF controller, styles) #}
    <script type="module">
        import 'app';
    </script>
</body>
</html>