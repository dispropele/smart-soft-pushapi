{% extends "base.html.twig" %}

{% block title %}Вход в личный кабинет — Аурум Ломбард{% endblock %}

{% block body %}
{# Комментарии теперь внутри блока или в формате Twig #}
<div class="min-h-[calc(100vh-200px)] flex items-center justify-center py-12 px-4">
    <div class="bg-white w-full max-w-sm rounded-[3px] shadow-[0_12px_40px_rgba(0,0,0,.15)] border border-[#c8d7e1] overflow-hidden">
        
        {# Заголовок как в админке #}
        <div class="bg-[#e1f0f5] border-b-[3px] border-[#2d6ca2] p-6 text-center">
            <h1 class="text-xl font-bold text-[#1d4e75] tracking-tight">Личный кабинет</h1>
            <p class="text-xs text-[#7a9fb5] mt-1">Для клиентов ломбарда</p>
        </div>

        <div class="p-6">
            {% if error %}
                <div class="bg-[#fdf3f3] border border-[#f5c6cb] text-[#721c24] rounded-[2px] p-3 text-sm mb-5">
                    ⚠ {{ error }}
                </div>
            {% endif %}

            <form method="POST" class="space-y-4">
                <div>
                    <label for="fullName" class="block text-xs font-bold text-[#555] uppercase tracking-wide mb-1.5">
                        ФИО
                    </label>
                    <input type="text" id="fullName" name="fullName" required autofocus
                           class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[2px] focus:outline-none focus:border-[#2d6ca2] focus:ring-2 focus:ring-[#2d6ca2]/20 transition text-sm">
                </div>

                <div>
                    <label for="ticketNumber" class="block text-xs font-bold text-[#555] uppercase tracking-wide mb-1.5">
                        Номер залогового билета
                    </label>
                    <input type="text" id="ticketNumber" name="ticketNumber" required
                           class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[2px] focus:outline-none focus:border-[#2d6ca2] focus:ring-2 focus:ring-[#2d6ca2]/20 transition text-sm"
                           placeholder="Например: ЛБ-2026-0504">
                </div>

                <button type="submit"
                        class="w-full mt-4 bg-[#60b060] hover:bg-[#529a52] text-white font-bold py-2.5 px-4 rounded-[3px] border-b-2 border-black/20 active:border-b-0 active:mt-[18px] transition-all uppercase tracking-wide text-sm">
                    Войти
                </button>
            </form>

            <a href="{{ path('app_catalog') }}" class="block text-center mt-5 text-sm text-[#7a9fb5] hover:text-[#2d6ca2] transition">
                ← Вернуться в каталог
            </a>
        </div>
    </div>
</div>
{% endblock %}