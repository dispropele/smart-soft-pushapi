{% extends 'base.html.twig' %}

{% block title %}Корзина - Аурум Ломбард{% endblock %}

{% block body %}
<div class="mb-6 pb-4 border-b border-gray-200 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">
        Корзина
        <span class="text-sm font-normal text-gray-500 ml-2">{{ goods|length }} поз.</span>
    </h1>
    <a href="{{ path('app_catalog') }}" class="text-sm font-medium text-yellow-600 hover:text-yellow-700 transition">
        ← Продолжить покупки
    </a>
</div>

{% if goods is empty %}
    <div class="py-20 text-center text-gray-400 bg-white rounded-xl shadow-sm border border-gray-200">
        <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
        <p class="text-xl font-medium text-gray-600">Корзина пуста</p>
        <a href="{{ path('app_catalog') }}"
           class="mt-4 inline-block bg-yellow-100 text-yellow-800 hover:bg-yellow-200 font-semibold px-6 py-2 rounded-lg transition">
            Перейти в каталог
        </a>
    </div>
{% else %}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-4">
            {% for good in goods %}
                {% set cover = null %}
                {% for img in good.images %}{% if img.isCover and cover is null %}{% set cover = img %}{% endif %}{% endfor %}
                {% if cover is null and good.images|length > 0 %}{% set cover = good.images|first %}{% endif %}

                <div class="bg-white border border-gray-200 rounded-xl shadow-sm flex gap-4 p-4 hover:shadow-md transition" id="cart-item-{{ good.id }}">
                    <a href="{{ path('app_item_show', {id: good.id}) }}"
                       class="shrink-0 w-24 h-24 border border-gray-100 bg-gray-50 rounded-lg flex items-center justify-center overflow-hidden">
                        <img src="{{ cover ? cover.preview : '/img/no-photo.png' }}" class="w-full h-full object-contain p-2">
                    </a>

                    <div class="flex-1 min-w-0 py-1">
                        <a href="{{ path('app_item_show', {id: good.id}) }}"
                           class="text-base font-semibold text-gray-900 hover:text-yellow-600 transition leading-snug block truncate">
                            {{ good.name }}
                        </a>
                        {% if good.metalStandard %}
                        <div class="text-sm text-gray-500 mt-1">
                            {{ good.metalStandard.metal.name }} {{ good.metalStandard.name }}
                            {% if good.metalColor %} · {{ good.metalColor.name }}{% endif %}
                        </div>
                        {% endif %}
                        <div class="text-xl font-bold text-gray-900 mt-2">
                            {{ good.soldPrice|number_format(0, '.', ' ') }}&thinsp;<span class="text-base font-normal text-gray-500">{{ good.currency ? good.currency.currency : '₽' }}</span>
                        </div>
                    </div>

                    <button onclick="removeFromCart({{ good.id }})" class="shrink-0 text-gray-400 hover:text-red-500 transition-colors p-2 self-start" title="Удалить">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
            {% endfor %}
        </div>

        <div>
            <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 sticky top-6">
                <div class="text-lg font-bold text-gray-900 mb-4 pb-4 border-b border-gray-100">Итого к оплате</div>
                <div class="space-y-3 mb-6">
                    <div class="flex justify-between text-gray-600">
                        <span>Позиций:</span>
                        <span class="font-medium text-gray-900">{{ goods|length }} шт.</span>
                    </div>
                    {% set total = 0 %}
                    {% for g in goods %}{% set total = total + g.soldPrice %}{% endfor %}
                    <div class="flex justify-between items-center border-t border-gray-100 pt-3 mt-3">
                        <span class="text-gray-600">Сумма:</span>
                        <span class="text-2xl font-bold text-gray-900">{{ total|number_format(0, '.', ' ') }} ₽</span>
                    </div>
                </div>

                <button class="w-full py-3.5 bg-yellow-500 hover:bg-yellow-600 text-white font-bold rounded-lg transition shadow-md"
                        onclick="alert('Для резервирования свяжитесь с ломбардом по телефону.')">
                    Оформить заявку
                </button>
                <p class="text-sm text-gray-500 text-center mt-4">Резервирование по телефону</p>
            </div>
        </div>
    </div>
{% endif %}

<script>
function removeFromCart(id) {
    fetch('/cart/remove/' + id, { method: 'POST' })
        .then(r => r.json())
        .then(d => {
            document.getElementById('cart-item-' + id)?.remove();
            const el = document.getElementById('cartCount');
            if (el) el.textContent = d.count;
            if (d.count === 0) location.reload();
        });
}
</script>
{% endblock %}