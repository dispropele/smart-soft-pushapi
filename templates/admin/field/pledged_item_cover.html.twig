{# Шаблон для отображения обложки (первого фото) залогового предмета в админке #}
{% if field.value and field.value.images|length > 0 %}
    {% set cover = null %}
    {% for img in field.value.images %}
        {% if img.isCover and cover is null %}
            {% set cover = img %}
        {% endif %}
    {% endfor %}
    {% if cover is null %}
        {% set cover = field.value.images|first %}
    {% endif %}
    
    {% if cover and cover.preview %}
        <img src="{{ cover.preview }}" alt="{{ field.value.name }}" style="max-width: 100px; max-height: 100px; object-fit: cover;" />
    {% endif %}
{% else %}
    <span class="text-muted">Нет фото</span>
{% endif %}
