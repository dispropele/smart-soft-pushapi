# Render deployment environment configuration
# Set these variables in Render Dashboard → Web Service → Environment Variables
#
# Generate APP_SECRET with:
#   php -r 'echo bin2hex(random_bytes(16));'
#
# DATABASE_URL will be auto-generated from PostgreSQL service if using render.yaml

###> Symfony Core ###
APP_ENV=prod
APP_DEBUG=0
###< Symfony Core ###

###> Security ###
# Generate new value for production: php -r 'echo bin2hex(random_bytes(16));'
APP_SECRET=YOUR_GENERATED_SECRET_HERE
###< Security ###

###> Custom App Variables ###
SMARTLOMBARD_API_SECRET=your-api-secret-here
DEFAULT_URI=https://your-app.onrender.com
###< Custom App Variables ###

###> Doctrine/Database ###
# Format: postgresql://user:password@host:port/database_name
# Auto-set from render.yaml if using PostgreSQL service
DATABASE_URL="postgresql://app:password@db.onrender.com:5432/app?serverVersion=16&charset=utf8"
###< Doctrine/Database ###

###> Messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< Messenger ###

###> Mailer ###
# For production, use a real mail service (e.g., SendGrid, Mailgun)
# Example for SendGrid:
#   MAILER_DSN=sendgrid+api://SG.your-key@default
MAILER_DSN=sendmail://default
###< Mailer ###

###> Framework ###
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
TRUSTED_HOSTS='^([a-z0-9-]+(\.onrender\.com|\.localhost|127\.0\.0\.1))?$'
###< Framework ###

###> File Upload ###
UPLOAD_MAX_FILESIZE=100M
POST_MAX_SIZE=100M
###< File Upload ###

###> System ###
TZ=UTC
###< System ###
