{# templates/admin/field/pledged_items_detail.html.twig #}
{% if field.value is not empty %}
    <div class="card mt-3">
        <div class="card-header bg-light">
            <strong><i class="fa fa-cubes"></i> Предметы залога</strong>
            <span class="badge bg-secondary ms-2">{{ field.value|length }} шт.</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>№</th>
                        <th>Название</th>
                        <th>Вид</th>
                        <th>Металл</th>
                        <th>Вес (г)</th>
                        <th>Вставка</th>
                        <th>Цвет</th>
                        <th>Вес лома</th>
                        <th>Оценка</th>
                        <th>Статус</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in field.value %}
                        {% set statusClass = 'bg-light text-dark' %}
                        {% if item.status == 'pledged' %}{% set statusClass = 'bg-primary text-white' %}{% endif %}
                        {% if item.status == 'redeemed' %}{% set statusClass = 'bg-success text-white' %}{% endif %}
                        {% if item.status == 'for_sale' %}{% set statusClass = 'bg-warning text-dark' %}{% endif %}
                        {% if item.status == 'sold' %}{% set statusClass = 'bg-danger text-white' %}{% endif %}
                        {% if item.status == 'withdrawn' %}{% set statusClass = 'bg-secondary text-white' %}{% endif %}
                        <tr>
                            <td>{{ loop.index }}</td>
                            <td>
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\PledgedItemCrudController').setAction('detail').setEntityId(item.id) }}">
                                    {{ item.name }}
                                </a>
                            </td>
                            <td>{{ item.goodType ?? '—' }}</td>
                            <td>{{ item.metalStandard ?? '—' }}</td>
                            <td>{{ item.itemWeight ? item.itemWeight ~ ' г' : '—' }}</td>
                            <td>
                                {% if item.insert %}
                                    {{ item.insert }}
                                    {% if item.insertWeight %}
                                        ({{ item.insertWeight }} г)
                                    {% endif %}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>{{ item.metalColor ? item.metalColor.name : '—' }}</td>
                            <td>{{ item.scrapWeight ? item.scrapWeight ~ ' г' : '—' }}</td>
                            <td>
                                {% if item.estimatedValue %}
                                    <strong>{{ item.estimatedValue|number_format(2, '.', ' ') }} ₽</strong>
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge {{ statusClass }}">{{ item.statusLabel }}</span>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% else %}
    <div class="alert alert-light mt-3">
        <i class="fa fa-info-circle"></i> Предметы залога не добавлены.
    </div>
{% endif %}
