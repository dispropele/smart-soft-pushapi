{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Сводка{% endblock %}

{% block main %}
<div class="container-fluid px-0">

    {# 5.1. Заголовок и кнопка #}
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <a href="{{ createTicketUrl }}" class="btn btn-primary">
            <i class="fa fa-plus me-2"></i>Создать залоговый билет
        </a>

        <form method="post" action="{{ updateStatusesUrl }}" class="m-0">
            <input type="hidden" name="_token" value="{{ csrf_token('update_ticket_statuses') }}">
            <button type="submit" class="btn btn-outline-secondary">
                <i class="fa fa-sync-alt me-2"></i>Обновить статусы билетов
            </button>
        </form>
    </div>

    {# 5.4.a. Верхний ряд: 4 карточки-индикатора #}
    <div class="row g-4 mb-4">
        <!-- Займы активные -->
        <div class="col-md-3">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase fw-bold mb-2">Займы (Активные)</h6>
                    <h3 class="text-dark mb-0 fw-bold">{{ (activeLoansSum)|number_format(2, '.', ' ') }} ₽</h3>
                </div>
            </div>
        </div>
        <!-- Льготный период -->
        <div class="col-md-3">
            <div class="card shadow-sm h-100 border-0" style="border-left: 4px solid #ffc107 !important;">
                <div class="card-body">
                    <h6 class="text-warning text-uppercase fw-bold mb-2" style="color: #ffc107 !important;">Льготный период</h6>
                    <h3 class="mb-0 fw-bold" style="color: #ffc107;">{{ (graceLoansSum)|number_format(2, '.', ' ') }} ₽</h3>
                </div>
            </div>
        </div>
        <!-- Просроченные -->
        <div class="col-md-3">
            <div class="card shadow-sm h-100 border-0" style="border-left: 4px solid #dc3545 !important;">
                <div class="card-body">
                    <h6 class="text-danger text-uppercase fw-bold mb-2" style="color: #dc3545 !important;">Просроченные</h6>
                    <h3 class="mb-0 fw-bold" style="color: #dc3545;">{{ (expiredLoansSum)|number_format(2, '.', ' ') }} ₽</h3>
                </div>
            </div>
        </div>
        <!-- Изделия на витрине -->
        <div class="col-md-3">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase fw-bold mb-2">Изделия на витрине</h6>
                    <h3 class="text-dark mb-0 fw-bold">{{ (onSaleValue)|number_format(2, '.', ' ') }} ₽</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        {# 5.4.b. Центр (слева): График #}
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-dark mb-4">Динамика денежных потоков</h5>
                    {# 5.2. График за неделю #}
                    <div style="position: relative; width: 100%;">
                        <canvas id="cashflowChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        {# 5.4.c. Центр (справа): Последние 5 операций #}
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-dark mb-4">Последние 5 операций</h5>
                    <div class="list-group list-group-flush">
                        {% for op in latestOperations %}
                            <div class="list-group-item px-0 py-3 d-flex align-items-center border-bottom">
                                {% if op.ticketNumber is defined and op.ticketNumber %}
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 me-3" style="width: 40px; height: 40px;">
                                        <i class="fa fa-file-text"></i>
                                    </div>
                                    <div>
                                        <p class="mb-1 fw-semibold small">Новый билет <a href="{{ ea_url().setController('App\\Controller\\Admin\\LoanTicketCrudController').setAction('detail').setEntityId(op.id) }}" class="text-decoration-none">{{ op.ticketNumber }}</a></p>
                                        <p class="mb-0 text-muted" style="font-size: 0.75rem;">{{ op.issuedAt|date('d.m.Y H:i') }} &middot; {{ op.loanAmount|number_format(2, '.', ' ') }} ₽</p>
                                    </div>
                                {% else %}
                                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 me-3" style="width: 40px; height: 40px;">
                                        <i class="fa fa-shopping-cart"></i>
                                    </div>
                                    <div>
                                        <p class="mb-1 fw-semibold small">Продажа <a href="{{ ea_url().setController('App\\Controller\\Admin\\PledgedItemCrudController').setAction('detail').setEntityId(op.id) }}" class="text-success text-decoration-none">{{ op.name }}</a></p>
                                        <p class="mb-0 text-muted" style="font-size: 0.75rem;">{{ op.statusDate|date('d.m.Y H:i') }} &middot; {{ op.soldPrice|number_format(2, '.', ' ') }} ₽</p>
                                    </div>
                                {% endif %}
                            </div>
                        {% else %}
                            <p class="text-muted text-center py-4 mb-0">Операций пока нет.</p>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# 5.3. Справочники #}
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h5 class="card-title fw-bold text-dark mb-4">Справочники</h5>
            <div class="row g-3 text-center">
                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\CategoryCrudController') }}" class="d-block p-3 bg-light rounded text-decoration-none text-dark custom-hover">
                        <i class="fa fa-folder fa-2x mb-2 text-secondary"></i><span class="d-block small fw-semibold">Категории</span>
                    </a>
                </div>
                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\GoodTypeCrudController') }}" class="d-block p-3 bg-light rounded text-decoration-none text-dark custom-hover">
                        <i class="fa fa-ring fa-2x mb-2 text-secondary"></i><span class="d-block small fw-semibold">Виды изделий</span>
                    </a>
                </div>
                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\InsertTypeCrudController') }}" class="d-block p-3 bg-light rounded text-decoration-none text-dark custom-hover">
                        <i class="fa fa-gem fa-2x mb-2 text-secondary"></i><span class="d-block small fw-semibold">Типы вставок</span>
                    </a>
                </div>
                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\InsertCrudController') }}" class="d-block p-3 bg-light rounded text-decoration-none text-dark custom-hover">
                        <i class="fa fa-diamond fa-2x mb-2 text-secondary"></i><span class="d-block small fw-semibold">Вставки</span>
                    </a>
                </div>
                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\MetalColorCrudController') }}" class="d-block p-3 bg-light rounded text-decoration-none text-dark custom-hover">
                        <i class="fa fa-palette fa-2x mb-2 text-secondary"></i><span class="d-block small fw-semibold">Цвета металлов</span>
                    </a>
                </div>
                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\MetalCrudController') }}" class="d-block p-3 bg-light rounded text-decoration-none text-dark custom-hover">
                        <i class="fa fa-cubes fa-2x mb-2 text-secondary"></i><span class="d-block small fw-semibold">Металлы</span>
                    </a>
                </div>
                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\MetalStandardCrudController') }}" class="d-block p-3 bg-light rounded text-decoration-none text-dark custom-hover">
                        <i class="fa fa-certificate fa-2x mb-2 text-secondary"></i><span class="d-block small fw-semibold">Пробы</span>
                    </a>
                </div>
                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\TariffCrudController') }}" class="d-block p-3 bg-light rounded text-decoration-none text-dark custom-hover">
                        <i class="fa fa-percent fa-2x mb-2 text-secondary"></i><span class="d-block small fw-semibold">Тарифы</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .custom-hover { transition: all 0.2s ease-in-out; }
    .custom-hover:hover { background-color: #e9ecef !important; transform: translateY(-2px); }
    .custom-hover:hover i { color: #0d6efd !important; }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('cashflowChart')?.getContext('2d');
    if (!ctx) return;

    // Заглушка данных для проверки визуала, если переменная пустая
    const rawData = {{ cashflowData|default('[]')|json_encode|raw }};
    const data = rawData;
    
    const labels = data.map(d => d.date);
    const issuedData = data.map(d => d.issued);
    const receivedData = data.map(d => d.received);

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [
                {
                    label: 'Выдано (займы)',
                    data: issuedData,
                    borderColor: '#dc3545', // Bootstrap Danger
                    backgroundColor: 'rgba(220, 53, 69, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: true,
                    pointRadius: 4,
                    pointBackgroundColor: '#dc3545',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                },
                {
                    label: 'Получено (выкупы + продажи)',
                    data: receivedData,
                    borderColor: '#198754', // Bootstrap Success
                    backgroundColor: 'rgba(25, 135, 84, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: true,
                    pointRadius: 4,
                    pointBackgroundColor: '#198754',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: true,
                    position: 'top',
                    labels: {
                        usePointStyle: true,
                        padding: 15,
                        font: { size: 13 }
                    }
                },
                tooltip: {
                    mode: 'index',
                    intersect: false,
                    backgroundColor: 'rgba(0,0,0,0.8)',
                    titleFont: { size: 12 },
                    bodyFont: { size: 12 },
                    padding: 10,
                    callbacks: {
                        label: function(context) {
                            let label = context.dataset.label || '';
                            if (label) label += ': ';
                            label += new Intl.NumberFormat('ru-RU', {
                                style: 'currency',
                                currency: 'RUB',
                                minimumFractionDigits: 0,
                                maximumFractionDigits: 0
                            }).format(context.parsed.y);
                            return label;
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: 'rgba(0,0,0,0.05)' },
                    ticks: {
                        callback: function(value) {
                            return new Intl.NumberFormat('ru-RU', {
                                style: 'currency',
                                currency: 'RUB',
                                minimumFractionDigits: 0,
                                maximumFractionDigits: 0
                            }).format(value);
                        }
                    }
                },
                x: {
                    grid: { display: false }
                }
            }
        }
    });
});
</script>
{% endblock %}