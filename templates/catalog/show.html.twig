{% extends 'base.html.twig' %}

{% block title %}{{ good.name }} — Аурум Ломбард{% endblock %}

{% block body %}
{# Хлебные крошки #}
<nav class="text-xs text-[#7a9fb5] mb-6 flex items-center gap-2 flex-wrap">
    <a href="{{ path('app_catalog') }}" class="text-[#2d6ca2] hover:underline">Каталог</a>
    <span>›</span>
    {% if good.category %}
        <span>{{ good.category.name }}</span>
        <span>›</span>
    {% endif %}
    <span class="text-[#333] font-medium truncate">{{ good.name }}</span>
</nav>

{# Сетка: 2 колонки (Фото слева, Инфо справа) #}
<div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
    
    {# Левая колонка: Галерея #}
    <div class="lg:col-span-2 space-y-4">
        {# Главное фото с жестким ограничением размеров #}
        <div class="bg-white border border-[#c8d7e1] rounded-[3px] flex items-center justify-center overflow-hidden h-[400px] md:h-[500px] p-4 shadow-sm">
            {% set cover = null %}
            {% for img in good.images %}{% if img.isCover and cover is null %}{% set cover = img %}{% endif %}{% endfor %}
            {% if cover is null and good.images|length > 0 %}{% set cover = good.images|first %}{% endif %}

            <img id="mainImage" src="{{ cover ? cover.src : '/img/no-photo.png' }}" alt="{{ good.name }}" 
                 class="max-w-full max-h-full object-contain">
        </div>

        {# Миниатюры #}
        {% if good.images|length > 1 %}
            <div class="flex gap-2 overflow-x-auto pb-2">
                {% for img in good.images %}
                    <button onclick="document.getElementById('mainImage').src='{{ img.src }}'"
                            class="w-16 h-16 shrink-0 border border-[#c8d7e1] rounded-[2px] overflow-hidden hover:border-[#2d6ca2] transition-colors bg-white">
                        <img src="{{ img.preview }}" class="w-full h-full object-cover">
                    </button>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# Правая колонка: Информация #}
    <div class="lg:col-span-3">
        <div class="mb-4">
            <span class="text-xs text-[#7a9fb5] bg-[#e1f0f5] px-2 py-1 rounded-[2px]">Арт. {{ good.id }}</span>
        </div>

        <h1 class="text-2xl md:text-3xl font-bold text-[#1d4e75] mb-6 leading-tight">{{ good.name }}</h1>

        {# Цена #}
        <div class="bg-white border border-[#c8d7e1] rounded-[3px] p-6 mb-8 shadow-sm">
            <div class="text-4xl font-bold text-[#333] mb-2">
                {{ good.soldPrice|number_format(0, '.', ' ') }} <span class="text-xl font-normal text-[#7a9fb5]">{{ good.currency ? good.currency.currency : '₽' }}</span>
            </div>
            <p class="text-sm text-[#7a9fb5]">Уточняйте наличие и условия резервирования по телефону.</p>
        </div>

        {# Характеристики #}
        <div class="bg-white border border-[#c8d7e1] rounded-[3px] mb-6 overflow-hidden shadow-sm">
            <div class="bg-[#f8fbfd] border-b border-[#c8d7e1] px-5 py-3 font-bold text-[#1d4e75]">Характеристики</div>
            <table class="w-full text-sm">
                <tbody>
                    {% if good.metalStandard %}
                        <tr class="border-b border-[#f0f4f8]">
                            <td class="px-5 py-3 text-[#7a9fb5] w-1/3">Металл / проба</td>
                            <td class="px-5 py-3 text-[#333] font-medium">{{ good.metalStandard.metal.name }} — {{ good.metalStandard.name }}</td>
                        </tr>
                    {% endif %}
                    {% if good.size %}
                        <tr class="border-b border-[#f0f4f8]">
                            <td class="px-5 py-3 text-[#7a9fb5]">Размер</td>
                            <td class="px-5 py-3 text-[#333] font-medium">{{ good.size }}</td>
                        </tr>
                    {% endif %}
                    <tr class="border-b border-[#f0f4f8]">
                        <td class="px-5 py-3 text-[#7a9fb5]">Филиал</td>
                        <td class="px-5 py-3 text-[#333]">{{ good.merchant.name }}</td>
                    </tr>
                    {% if good.merchant.city %}
                        <tr class="border-b border-[#f0f4f8]">
                            <td class="px-5 py-3 text-[#7a9fb5]">Город</td>
                            <td class="px-5 py-3 text-[#333]">{{ good.merchant.city.name }}</td>
                        </tr>
                    {% endif %}
                    {% if good.merchant.phone %}
                        <tr>
                            <td class="px-5 py-3 text-[#7a9fb5]">Телефон</td>
                            <td class="px-5 py-3 font-bold text-[#2d6ca2]">{{ good.merchant.phone }}</td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>

        {# Описание #}
        {% if good.description %}
            <div class="bg-white border border-[#c8d7e1] rounded-[3px] shadow-sm overflow-hidden">
                <div class="bg-[#f8fbfd] border-b border-[#c8d7e1] px-5 py-3 font-bold text-[#1d4e75]">Описание</div>
                <div class="px-5 py-4 text-sm text-[#555] leading-relaxed whitespace-pre-line">{{ good.description }}</div>
            </div>
        {% endif %}
    </div>
</div>

<div class="mt-8">
    <a href="{{ path('app_catalog') }}" class="text-sm text-[#2d6ca2] hover:underline">← Вернуться в каталог</a>
</div>
{% endblock %}