{% extends 'base.html.twig' %}

{% block title %}Каталог товаров — Аурум Ломбард{% endblock %}

{% block body %}
<div class="mb-6 pb-4 border-b border-[#c8d7e1]">
    <h1 class="text-2xl font-bold text-[#1d4e75]">
        {% if search %}
            Результаты поиска: «{{ search }}»
        {% else %}
            Каталог товаров
        {% endif %}
    </h1>
    <p class="text-sm text-[#7a9fb5] mt-1">Найдено: {{ total }} поз.</p>
</div>

<!-- Фильтры -->
<div class="mb-6 bg-white border border-[#c8d7e1] rounded-[3px] p-4">
    <form method="GET" class="space-y-4" id="filterForm">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Поиск -->
            <div>
                <label class="block text-sm font-semibold text-[#1d4e75] mb-2">Поиск</label>
                <input type="text" name="q" value="{{ search }}" placeholder="Название товара..."
                    class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[3px] text-sm focus:outline-none focus:border-[#2d6ca2]">
            </div>

            <!-- Цена минимальная -->
            <div>
                <label class="block text-sm font-semibold text-[#1d4e75] mb-2">Цена от</label>
                <input type="number" name="price_min" value="{{ priceMin }}" placeholder="0" step="100" min="0"
                    class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[3px] text-sm focus:outline-none focus:border-[#2d6ca2]">
            </div>

            <!-- Цена максимальная -->
            <div>
                <label class="block text-sm font-semibold text-[#1d4e75] mb-2">Цена до</label>
                <input type="number" name="price_max" value="{{ priceMax }}" placeholder="без ограничений" step="100" min="0"
                    class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[3px] text-sm focus:outline-none focus:border-[#2d6ca2]">
            </div>

            <!-- Сортировка -->
            <div>
                <label class="block text-sm font-semibold text-[#1d4e75] mb-2">Сортировка</label>
                <select name="sort" class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[3px] text-sm focus:outline-none focus:border-[#2d6ca2]">
                    <option value="date" {% if sort == 'date' %}selected{% endif %}>По новизне</option>
                    <option value="price_asc" {% if sort == 'price_asc' %}selected{% endif %}>Цена (↑)</option>
                    <option value="price_desc" {% if sort == 'price_desc' %}selected{% endif %}>Цена (↓)</option>
                    <option value="name" {% if sort == 'name' %}selected{% endif %}>По названию</option>
                </select>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <!-- Категория -->
            <div>
                <label class="block text-sm font-semibold text-[#1d4e75] mb-2">Категория</label>
                <select name="category" class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[3px] text-sm focus:outline-none focus:border-[#2d6ca2]" id="categorySelect">
                    <option value="">Все категории</option>
                    {% for cat in categories %}
                        <option value="{{ cat.id }}" {% if categoryId == cat.id %}selected{% endif %}>{{ cat.name }}</option>
                    {% endfor %}
                </select>
            </div>

            <!-- Вид изделия -->
            <div>
                <label class="block text-sm font-semibold text-[#1d4e75] mb-2">Вид изделия</label>
                <select name="type" class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[3px] text-sm focus:outline-none focus:border-[#2d6ca2]" id="typeSelect">
                    <option value="">Все виды</option>
                </select>
            </div>

            <!-- Кнопки -->
            <div class="flex items-end gap-2">
                <button type="submit" class="flex-1 px-4 py-2 bg-[#2d6ca2] text-white text-sm font-semibold rounded-[3px] hover:bg-[#1d4e75] transition">
                    Применить
                </button>
                <a href="{{ path('app_catalog') }}" class="px-4 py-2 border border-[#c8d7e1] text-[#7a9fb5] text-sm font-semibold rounded-[3px] hover:bg-[#f0f4f8] transition">
                    Сброс
                </a>
            </div>
        </div>
    </form>
</div>

{% if goods is empty %}
    <div class="py-20 text-center bg-white border border-[#c8d7e1] rounded-[3px]">
        <p class="text-lg text-[#7a9fb5]">Товары не найдены</p>
        <a href="{{ path('app_catalog') }}" class="mt-4 inline-block text-[#2d6ca2] hover:underline text-sm">Сбросить фильтры</a>
    </div>
{% else %}
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-5">
        {% for good in goods %}
            {% set cover = null %}
            {% for img in good.images %}{% if img.isCover and cover is null %}{% set cover = img %}{% endif %}{% endfor %}
            {% if cover is null and good.images|length > 0 %}{% set cover = good.images|first %}{% endif %}

            <div class="bg-white border border-[#c8d7e1] rounded-[3px] flex flex-col hover:shadow-[0_4px_12px_rgba(0,0,0,0.1)] hover:border-[#2d6ca2] transition-all duration-200">

                <a href="{{ path('app_product_show', {id: good.id}) }}" class="block relative border-b border-[#f0f4f8] bg-white p-4 h-48 flex items-center justify-center">
                    <img src="{{ cover ? cover.preview : '/img/no-photo.png' }}" class="max-w-full max-h-full object-contain" alt="{{ good.name }}">
                    <span class="absolute top-2 left-2 bg-[#f8fbfd] text-[#7a9fb5] text-[10px] px-1.5 py-0.5 border border-[#c8d7e1] rounded-[2px]">#{{ good.id }}</span>
                </a>

                <div class="p-4 flex flex-col flex-grow">
                    <a href="{{ path('app_product_show', {id: good.id}) }}" class="text-sm font-semibold text-[#1d4e75] hover:underline mb-2 line-clamp-2 min-h-[40px]">
                        {{ good.name }}
                    </a>

                    {% if good.metalStandard %}
                        <p class="text-xs text-[#7a9fb5] mb-1">{{ good.metalStandard.metal.name }} {{ good.metalStandard.name }}</p>
                    {% endif %}

                    <div class="text-lg font-bold text-[#333] mt-auto mb-3">
                        {{ good.soldPrice|number_format(0, '.', ' ') }} <span class="text-xs font-normal text-[#7a9fb5]">{{ good.currency ? good.currency.currency : '₽' }}</span>
                    </div>

                    <a href="{{ path('app_product_show', {id: good.id}) }}" class="block text-center text-xs font-bold uppercase tracking-wide py-2 bg-[#e1f0f5] text-[#1d4e75] rounded-[2px] hover:bg-[#c8d7e1] transition">
                        Подробнее
                    </a>
                </div>
            </div>
        {% endfor %}
    </div>

    {# ───────────────────────── ПАГИНАЦИЯ ───────────────────────── #}
    {% if pages > 1 %}
        <nav class="mt-8 flex items-center justify-center gap-1 flex-wrap" aria-label="Пагинация">
            {# Macro to build a page URL keeping all current filters #}
            {% macro page_url(p, search, sort, priceMin, priceMax, categoryId, goodTypeId) %}
                {{ path('app_catalog', {
                    page:      p,
                    q:         search,
                    sort:      sort,
                    price_min: priceMin,
                    price_max: priceMax,
                    category:  categoryId,
                    type:      goodTypeId
                }) }}
            {% endmacro %}

            {# Prev #}
            {% if page > 1 %}
                <a href="{{ _self.page_url(page - 1, search, sort, priceMin, priceMax, categoryId, goodTypeId) }}"
                   class="px-3 py-2 border border-[#c8d7e1] text-[#2d6ca2] text-sm rounded-[3px] hover:bg-[#e1f0f5] transition">
                    ‹
                </a>
            {% endif %}

            {# Page numbers with ellipsis #}
            {% set windowStart = max(1, page - 2) %}
            {% set windowEnd   = min(pages, page + 2) %}

            {% if windowStart > 1 %}
                <a href="{{ _self.page_url(1, search, sort, priceMin, priceMax, categoryId, goodTypeId) }}"
                   class="px-3 py-2 border border-[#c8d7e1] text-sm rounded-[3px] hover:bg-[#e1f0f5] transition text-[#333]">1</a>
                {% if windowStart > 2 %}
                    <span class="px-2 py-2 text-[#7a9fb5] text-sm">…</span>
                {% endif %}
            {% endif %}

            {% for p in windowStart..windowEnd %}
                {% if p == page %}
                    <span class="px-3 py-2 bg-[#2d6ca2] text-white text-sm rounded-[3px] font-bold">{{ p }}</span>
                {% else %}
                    <a href="{{ _self.page_url(p, search, sort, priceMin, priceMax, categoryId, goodTypeId) }}"
                       class="px-3 py-2 border border-[#c8d7e1] text-sm rounded-[3px] hover:bg-[#e1f0f5] transition text-[#333]">{{ p }}</a>
                {% endif %}
            {% endfor %}

            {% if windowEnd < pages %}
                {% if windowEnd < pages - 1 %}
                    <span class="px-2 py-2 text-[#7a9fb5] text-sm">…</span>
                {% endif %}
                <a href="{{ _self.page_url(pages, search, sort, priceMin, priceMax, categoryId, goodTypeId) }}"
                   class="px-3 py-2 border border-[#c8d7e1] text-sm rounded-[3px] hover:bg-[#e1f0f5] transition text-[#333]">{{ pages }}</a>
            {% endif %}

            {# Next #}
            {% if page < pages %}
                <a href="{{ _self.page_url(page + 1, search, sort, priceMin, priceMax, categoryId, goodTypeId) }}"
                   class="px-3 py-2 border border-[#c8d7e1] text-[#2d6ca2] text-sm rounded-[3px] hover:bg-[#e1f0f5] transition">
                    ›
                </a>
            {% endif %}
        </nav>
        <p class="text-center text-xs text-[#7a9fb5] mt-3">
            Страница {{ page }} из {{ pages }} · Показано {{ goods|length }} из {{ total }} товаров
        </p>
    {% endif %}
{% endif %}

<script>
document.addEventListener('DOMContentLoaded', function () {
    const categorySelect = document.getElementById('categorySelect');
    const typeSelect = document.getElementById('typeSelect');
    const currentTypeId = {{ goodTypeId ?? 'null' }};

    async function loadTypes(categoryId) {
        typeSelect.innerHTML = '<option value="">Все виды</option>';
        if (!categoryId) return;

        try {
            const response = await fetch(`/api/category/${categoryId}/types`);
            if (!response.ok) return;
            const types = await response.json();

            types.forEach(type => {
                const option = document.createElement('option');
                option.value = type.id;
                option.textContent = type.name;
                if (currentTypeId && type.id == currentTypeId) option.selected = true;
                typeSelect.appendChild(option);
            });
        } catch (error) {
            console.error('Ошибка загрузки видов изделий:', error);
        }
    }

    categorySelect.addEventListener('change', function () {
        loadTypes(this.value);
    });

    // On page load: restore types for selected category
    if (categorySelect.value) {
        loadTypes(categorySelect.value);
    }
});
</script>
{% endblock %}
