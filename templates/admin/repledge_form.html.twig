{# templates/admin/repledge_form.html.twig #}
{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Перезалог — {{ ticket.ticketNumber }}{% endblock %}

{% block main %}
<style>
    .repledge-items-table th,
    .repledge-items-table td {
        vertical-align: middle;
    }
    .repledge-totals {
        background: #f8f9fa;
        border-radius: 4px;
        padding: 1rem;
        margin-top: 1rem;
    }
    .repledge-totals .total-row {
        display: flex;
        justify-content: space-between;
        padding: .25rem 0;
    }
    .repledge-totals .total-row strong {
        font-size: 1.1rem;
    }
</style>

<div style="max-width:800px">
    <div style="background:#fff3cd;border:1px solid #ffc107;border-radius:4px;padding:1rem;margin-bottom:1.5rem">
        <strong>Билет:</strong> {{ ticket.ticketNumber }}<br>
        <strong>Тело займа:</strong> {{ ticket.loanAmount|number_format(2, '.', ' ') }} ₽<br>
        <strong>Накопилось процентов</strong> ({{ ticket.getElapsedDays() }} дн.):
        <strong>{{ accrued|number_format(2, '.', ' ') }} ₽</strong><br>
        <strong>Итого к погашению:</strong>
        <strong style="color:#1d4e75">{{ totalDebt|number_format(2, '.', ' ') }} ₽</strong>
    </div>

    {{ form_start(form) }}

    {# Items table with checkboxes #}
    <div class="card mb-4">
        <div class="card-header">
            <strong>Выберите изделия для выкупа</strong>
            <small class="text-muted ms-2">(отмеченные переходят в выкуп, остальные — в новый билет)</small>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover repledge-items-table mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:40px">Выкуп</th>
                        <th>Изделие</th>
                        <th>Оценка</th>
                        <th>Тело займа</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in ticket.pledgedItems %}
                        {% set itemLoan = itemLoans[item.id] ?? 0 %}
                        <tr>
                            <td class="text-center">
                                {{ form_widget(form['redeem_' ~ item.id], {
                                    'attr': {
                                        'class': 'redeem-checkbox',
                                        'data-item-id': item.id,
                                        'data-item-loan': itemLoan|number_format(2, '.', '')
                                    }
                                }) }}
                            </td>
                            <td>{{ item.name }}</td>
                            <td>{{ item.estimatedValue ? item.estimatedValue|number_format(2, '.', ' ') ~ ' ₽' : '—' }}</td>
                            <td class="item-loan-amount">{{ itemLoan|number_format(2, '.', ' ') }} ₽</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="repledge-totals mb-4">
        <div class="total-row">
            <span>Проценты к оплате:</span>
            <span id="accrued-interest">{{ accrued|number_format(2, '.', ' ') }} ₽</span>
        </div>
        <div class="total-row">
            <span>Сумма выкупа изделий:</span>
            <span id="redeemed-loan">0.00 ₽</span>
        </div>
        <div class="total-row border-top pt-2 mt-2">
            <strong>Итого к оплате для перезалога:</strong>
            <strong id="total-payment" style="color:#1d4e75">{{ accrued|number_format(2, '.', ' ') }} ₽</strong>
        </div>
        <div class="total-row">
            <span>Новое тело займа будет:</span>
            <strong id="new-body">{{ ticket.loanAmount|number_format(2, '.', ' ') }} ₽</strong>
        </div>
    </div>

    {{ form_row(form.paymentAmount) }}
    {{ form_row(form.extensionDays) }}
    {{ form_row(form.notes) }}
    <button type="submit" class="btn btn-warning btn-lg" id="submit-repledge">Оформить перезалог</button>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\LoanTicketCrudController').setAction('detail').setEntityId(ticket.id) }}"
       class="btn btn-secondary btn-lg ms-2">Отмена</a>
    {{ form_end(form) }}
</div>

<script>
(function() {
    const accrued = {{ accrued|number_format(2, '.', '') }};
    const totalLoan = {{ ticket.loanAmount|number_format(2, '.', '') }};

    function updateTotals() {
        let redeemedLoan = 0;
        document.querySelectorAll('.redeem-checkbox:checked').forEach(cb => {
            redeemedLoan += parseFloat(cb.dataset.itemLoan) || 0;
        });

        const totalPayment = accrued + redeemedLoan;
        const newBody = Math.max(0, totalLoan - redeemedLoan);

        document.getElementById('redeemed-loan').textContent = redeemedLoan.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') + ' ₽';
        document.getElementById('total-payment').textContent = totalPayment.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') + ' ₽';
        document.getElementById('new-body').textContent = newBody.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') + ' ₽';
    }

    document.querySelectorAll('.redeem-checkbox').forEach(cb => {
        cb.addEventListener('change', updateTotals);
    });
    updateTotals();
})();
</script>
{% endblock %}
