{% extends 'base.html.twig' %}

{% block title %}{{ item.name }} — Ломбард{% endblock %}

{% block body %}
<nav class="text-xs text-[#7a9fb5] mb-6 flex items-center gap-2 flex-wrap">
    <a href="{{ path('app_catalog') }}" class="text-[#2d6ca2] hover:underline">Каталог</a>
    <span>›</span>
    {% if item.category %}
        <span>{{ item.category.name }}</span>
        <span>›</span>
    {% endif %}
    <span class="text-[#333] font-medium truncate">{{ item.name }}</span>
</nav>

<div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

    <div class="lg:col-span-2 space-y-4">
        <div class="bg-white border border-[#c8d7e1] rounded-[3px] flex items-center justify-center overflow-hidden h-[400px] md:h-[500px] p-4 shadow-sm">
            {% set cover = null %}
            {% for img in item.images %}{% if img.isCover and cover is null %}{% set cover = img %}{% endif %}{% endfor %}
            {% if cover is null and item.images|length > 0 %}{% set cover = item.images|first %}{% endif %}
            <img id="mainImage" src="{{ cover ? cover.src : '/img/no-photo.png' }}" alt="{{ item.name }}"
                 class="max-w-full max-h-full object-contain">
        </div>

        {% if item.images|length > 1 %}
            <div class="flex gap-2 overflow-x-auto pb-2">
                {% for img in item.images %}
                    <button type="button" data-full-src="{{ img.src }}"
                            class="gallery-thumb w-16 h-16 shrink-0 border border-[#c8d7e1] rounded-[2px] overflow-hidden hover:border-[#2d6ca2] transition-colors bg-white">
                        <img src="{{ img.preview }}" alt="" class="w-full h-full object-cover">
                    </button>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <div class="lg:col-span-3">
        <div class="mb-4">
            <span class="text-xs text-[#7a9fb5] bg-[#e1f0f5] px-2 py-1 rounded-[2px]">Арт. {{ item.id }}</span>
            {% if item.category %}
                <span class="ml-2 text-xs text-[#7a9fb5] bg-[#f0f4f8] px-2 py-1 rounded-[2px]">{{ item.category.name }}</span>
            {% endif %}
            {% if item.goodType %}
                <span class="ml-2 text-xs text-[#7a9fb5] bg-[#f0f4f8] px-2 py-1 rounded-[2px]">{{ item.goodType.name }}</span>
            {% endif %}
        </div>

        <h1 class="text-2xl md:text-3xl font-bold text-[#1d4e75] mb-6 leading-tight">{{ item.name }}</h1>

        <div class="bg-white border border-[#c8d7e1] rounded-[3px] p-6 mb-6 shadow-sm">
            <div class="text-4xl font-bold text-[#333] mb-2">
                {{ item.displayPrice|default(0)|number_format(0, '.', ' ') }}&thinsp;<span class="text-xl font-normal text-[#7a9fb5]">{{ item.currency ? item.currency.currency : '₽' }}</span>
            </div>
            <a href="{{ path('app_item_purchase_request', {id: item.id}) }}" class="inline-flex items-center justify-center mt-4 w-full rounded-[3px] bg-[#2d6ca2] text-white font-bold py-3 text-sm hover:bg-[#244f7b] transition">
                Оставить заявку на покупку
            </a>
        </div>

        <div class="bg-white border border-[#c8d7e1] rounded-[3px] mb-6 overflow-hidden shadow-sm">
            <div class="bg-[#f8fbfd] border-b border-[#c8d7e1] px-5 py-3 font-bold text-[#1d4e75]">Характеристики</div>
            <table class="w-full text-sm">
                <tbody>

                    {% if item.goodType %}
                    <tr class="border-b border-[#f0f4f8]">
                        <td class="px-5 py-3 text-[#7a9fb5] w-2/5">Вид изделия</td>
                        <td class="px-5 py-3 text-[#333] font-medium">{{ item.goodType.name }}</td>
                    </tr>
                    {% endif %}

                    {% if item.metalStandard %}
                    <tr class="border-b border-[#f0f4f8]">
                        <td class="px-5 py-3 text-[#7a9fb5]">Металл / проба</td>
                        <td class="px-5 py-3 text-[#333] font-medium">
                            {{ item.metalStandard.metal.name }} — {{ item.metalStandard.name }}
                        </td>
                    </tr>
                    {% endif %}

                    {% if item.metalColor %}
                    <tr class="border-b border-[#f0f4f8]">
                        <td class="px-5 py-3 text-[#7a9fb5]">Цвет металла</td>
                        <td class="px-5 py-3 text-[#333] font-medium">{{ item.metalColor.name }}</td>
                    </tr>
                    {% endif %}

                    {% if item.insert %}
                    <tr class="border-b border-[#f0f4f8]">
                        <td class="px-5 py-3 text-[#7a9fb5]">Вставка</td>
                        <td class="px-5 py-3 text-[#333] font-medium">{{ item.insert.name }}</td>
                    </tr>
                    {% endif %}

                    {% if item.insertWeight %}
                    <tr class="border-b border-[#f0f4f8]">
                        <td class="px-5 py-3 text-[#7a9fb5]">Вес вставок</td>
                        <td class="px-5 py-3 text-[#333] font-medium">{{ item.insertWeight }} ct (карат)</td>
                    </tr>
                    {% endif %}

                    {% if item.insertDescription %}
                    <tr class="border-b border-[#f0f4f8]">
                        <td class="px-5 py-3 text-[#7a9fb5] align-top">Описание вставки</td>
                        <td class="px-5 py-3 text-[#333]">{{ item.insertDescription }}</td>
                    </tr>
                    {% endif %}

                    {% if item.size %}
                    <tr class="border-b border-[#f0f4f8]">
                        <td class="px-5 py-3 text-[#7a9fb5]">Размер/длина</td>
                        <td class="px-5 py-3 text-[#333] font-medium">{{ item.size }}</td>
                    </tr>
                    {% endif %}

                    {% if item.itemWeight %}
                    <tr class="border-b border-[#f0f4f8]">
                        <td class="px-5 py-3 text-[#7a9fb5]">Вес изделия</td>
                        <td class="px-5 py-3 text-[#333] font-medium">{{ item.itemWeight }} г</td>
                    </tr>
                    {% endif %}

                    {% if item.condition %}
                    <tr class="border-b border-[#f0f4f8]">
                        <td class="px-5 py-3 text-[#7a9fb5]">Состояние</td>
                        <td class="px-5 py-3 text-[#333] font-medium">{{ item.condition }}</td>
                    </tr>
                    {% endif %}

                    {% if item.displayPrice %}
                    <tr class="border-b border-[#f0f4f8]">
                        <td class="px-5 py-3 text-[#7a9fb5]">Цена</td>
                        <td class="px-5 py-3 text-[#333] font-medium">{{ item.displayPrice|number_format(0, '.', ' ') }} ₽</td>
                    </tr>
                    {% endif %}

                </tbody>
            </table>
        </div>

        {% if item.description %}
        <div class="bg-white border border-[#c8d7e1] rounded-[3px] shadow-sm overflow-hidden mb-6">
            <div class="bg-[#f8fbfd] border-b border-[#c8d7e1] px-5 py-3 font-bold text-[#1d4e75]">Описание</div>
            <div class="px-5 py-4 text-sm text-[#555] leading-relaxed whitespace-pre-line">{{ item.description }}</div>
        </div>
        {% endif %}

    </div>
</div>

<div class="mt-8">
    <a href="{{ path('app_catalog') }}" class="text-sm text-[#2d6ca2] hover:underline">← Вернуться в каталог</a>
</div>

<script>
document.querySelectorAll('.gallery-thumb').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var src = this.getAttribute('data-full-src');
        var main = document.getElementById('mainImage');
        if (src && main) main.src = src;
    });
});
</script>
{% endblock %}
