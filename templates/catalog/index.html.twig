{% extends 'base.html.twig' %}
{% block title %}Каталог — Аурум Ломбард{% endblock %}

{% block body %}
<div class="mb-6 pb-4 border-b border-[#c8d7e1]">
    <h1 class="text-2xl font-bold text-[#1d4e75]">
        {% if search %}Результаты поиска: «{{ search }}»{% else %}Витрина{% endif %}
    </h1>
    <p class="text-sm text-[#7a9fb5] mt-1">Найдено: {{ total }} поз.</p>
</div>

{# Фильтры #}
<div class="mb-6 bg-white border border-[#c8d7e1] rounded-[3px] p-4">
    <form method="GET" id="filterForm">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-4">
            <div>
                <label class="block text-xs font-bold text-[#1d4e75] mb-1 uppercase tracking-wide">Поиск</label>
                <input type="text" name="q" value="{{ search }}" placeholder="Название изделия…"
                    class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[3px] text-sm focus:outline-none focus:border-[#2d6ca2]">
            </div>
            <div>
                <label class="block text-xs font-bold text-[#1d4e75] mb-1 uppercase tracking-wide">Цена от</label>
                <input type="number" name="price_min" value="{{ priceMin }}" placeholder="0" step="100" min="0"
                    class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[3px] text-sm focus:outline-none focus:border-[#2d6ca2]">
            </div>
            <div>
                <label class="block text-xs font-bold text-[#1d4e75] mb-1 uppercase tracking-wide">Цена до</label>
                <input type="number" name="price_max" value="{{ priceMax }}" placeholder="1000" step="100" min="0"
                    class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[3px] text-sm focus:outline-none focus:border-[#2d6ca2]">
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-xs font-bold text-[#1d4e75] mb-1 uppercase tracking-wide">Категория</label>
                <select name="category" id="categorySelect" class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[3px] text-sm focus:outline-none focus:border-[#2d6ca2]">
                    <option value="">Все категории</option>
                    {% for cat in categories %}
                        <option value="{{ cat.id }}" {{ categoryId == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="block text-xs font-bold text-[#1d4e75] mb-1 uppercase tracking-wide">Вид изделия</label>
                <select name="type" id="typeSelect" class="w-full px-3 py-2 border border-[#c8d7e1] rounded-[3px] text-sm focus:outline-none focus:border-[#2d6ca2]">
                    <option value="">Все виды</option>
                </select>
            </div>
            <div class="flex items-end gap-2">
                <button type="submit" class="flex-1 px-4 py-2 bg-[#2d6ca2] text-white text-sm font-bold rounded-[3px] hover:bg-[#1d4e75] transition uppercase tracking-wide">
                    Применить
                </button>
                <a href="{{ path('app_catalog') }}" class="px-4 py-2 border border-[#c8d7e1] text-[#7a9fb5] text-sm font-bold rounded-[3px] hover:bg-[#f0f4f8] transition">
                    Сброс
                </a>
            </div>
        </div>
    </form>
</div>

{% if items is empty %}
    <div class="py-20 text-center bg-white border border-[#c8d7e1] rounded-[3px]">
        <p class="text-lg text-[#7a9fb5]">Товары не найдены</p>
        <a href="{{ path('app_catalog') }}" class="mt-4 inline-block text-[#2d6ca2] hover:underline text-sm">Сбросить фильтры</a>
    </div>
{% else %}
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
        {% for item in items %}
            {% set cover = null %}
            {% for img in item.images %}{% if img.isCover and cover is null %}{% set cover = img %}{% endif %}{% endfor %}
            {% if cover is null and item.images|length > 0 %}{% set cover = item.images|first %}{% endif %}

            <div class="bg-white border border-[#c8d7e1] rounded-[3px] flex flex-col hover:shadow-[0_4px_12px_rgba(0,0,0,.1)] hover:border-[#2d6ca2] transition-all">
                <a href="{{ path('app_item_show', {id: item.id}) }}"
                   class="block relative border-b border-[#f0f4f8] bg-white p-4 h-48 flex items-center justify-center">
                    <img src="{{ cover ? cover.preview : '/img/no-photo.png' }}"
                         class="max-w-full max-h-full object-contain" alt="{{ item.name }}">
                    {% if item.publishedAt and date(item.publishedAt) > date('-7 days') %}
                        <span class="absolute top-2 left-2 bg-[#e85d5d] text-white text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-[2px] shadow-sm">
                            Новинка
                        </span>
                    {% endif %}
                </a>

                <div class="p-3 flex flex-col flex-grow">
                    <a href="{{ path('app_item_show', {id: item.id}) }}"
                       class="text-sm font-semibold text-[#1d4e75] hover:underline mb-1 line-clamp-2 min-h-[40px]">
                        {{ item.name }}
                    </a>

                    {% if item.metalStandard %}
                        <p class="text-xs text-[#7a9fb5] mb-1">
                            {{ item.metalStandard.metal.name }} {{ item.metalStandard.name }}
                            {% if item.metalColor %} · {{ item.metalColor.name }}{% endif %}
                        </p>
                    {% endif %}

                    {% if item.itemInserts|length > 0 %}
                        <p class="text-xs text-[#7a9fb5] mb-1">
                            Вставки:
                            {% for ins in item.itemInserts %}
                                {{ ins.insert.name }}{% if ins.quantity > 1 %} ×{{ ins.quantity }}{% endif %}{% if not loop.last %}, {% endif %}
                            {% endfor %}
                        </p>
                    {% endif %}

                    <div class="text-xs text-[#7a9fb5] mb-2 space-y-0.5">
                        {% if item.itemWeight %}<div>Вес: {{ item.itemWeight }} г</div>{% endif %}
                        {% if item.size %}<div>Размер/длина: {{ item.size }}</div>{% endif %}
                        {% if item.condition %}<div>Состояние: {{ item.condition }}</div>{% endif %}
                    </div>

                    <div class="text-xl font-black text-[#333] mt-auto mb-2 tracking-tight">
                        {{ item.displayPrice|default(0)|number_format(0, '.', ' ') }}&nbsp;<span class="text-lg font-bold">{{ item.currency ? (item.currency.currency == 'RUB' ? '₽' : item.currency.currency) : '₽' }}</span>
                    </div>

                    <a href="{{ path('app_item_show', {id: item.id}) }}"
                       class="block text-center text-xs font-bold uppercase tracking-wide py-2 bg-[#e1f0f5] text-[#1d4e75] rounded-[2px] hover:bg-[#c8d7e1] transition">
                        Подробнее
                    </a>
                </div>
            </div>
        {% endfor %}
    </div>

    {# Пагинация #}
    {% if pages > 1 %}
        {% macro page_url(p, search, sort, priceMin, priceMax, categoryId, goodTypeId) %}
            {{ path('app_catalog', {page: p, q: search, sort: sort, price_min: priceMin, price_max: priceMax, category: categoryId, type: goodTypeId}) }}
        {% endmacro %}

        <nav class="mt-8 flex items-center justify-center gap-1 flex-wrap">
            {% if page > 1 %}
                <a href="{{ _self.page_url(page-1, search, sort, priceMin, priceMax, categoryId, goodTypeId) }}"
                   class="px-3 py-2 border border-[#c8d7e1] text-[#2d6ca2] text-sm rounded-[3px] hover:bg-[#e1f0f5]">‹</a>
            {% endif %}

            {% set ws = max(1, page-2) %}
            {% set we = min(pages, page+2) %}
            {% if ws > 1 %}
                <a href="{{ _self.page_url(1, search, sort, priceMin, priceMax, categoryId, goodTypeId) }}"
                   class="px-3 py-2 border border-[#c8d7e1] text-sm rounded-[3px] hover:bg-[#e1f0f5]">1</a>
                {% if ws > 2 %}<span class="px-2 text-[#7a9fb5]">…</span>{% endif %}
            {% endif %}
            {% for p in ws..we %}
                {% if p == page %}
                    <span class="px-3 py-2 bg-[#2d6ca2] text-white text-sm rounded-[3px] font-bold">{{ p }}</span>
                {% else %}
                    <a href="{{ _self.page_url(p, search, sort, priceMin, priceMax, categoryId, goodTypeId) }}"
                       class="px-3 py-2 border border-[#c8d7e1] text-sm rounded-[3px] hover:bg-[#e1f0f5]">{{ p }}</a>
                {% endif %}
            {% endfor %}
            {% if we < pages %}
                {% if we < pages-1 %}<span class="px-2 text-[#7a9fb5]">…</span>{% endif %}
                <a href="{{ _self.page_url(pages, search, sort, priceMin, priceMax, categoryId, goodTypeId) }}"
                   class="px-3 py-2 border border-[#c8d7e1] text-sm rounded-[3px] hover:bg-[#e1f0f5]">{{ pages }}</a>
            {% endif %}
            {% if page < pages %}
                <a href="{{ _self.page_url(page+1, search, sort, priceMin, priceMax, categoryId, goodTypeId) }}"
                   class="px-3 py-2 border border-[#c8d7e1] text-[#2d6ca2] text-sm rounded-[3px] hover:bg-[#e1f0f5]">›</a>
            {% endif %}
        </nav>
        <p class="text-center text-xs text-[#7a9fb5] mt-2">Страница {{ page }} из {{ pages }} · {{ items|length }} из {{ total }}</p>
    {% endif %}
{% endif %}

<script>
document.addEventListener('DOMContentLoaded', () => {
    const catSel  = document.getElementById('categorySelect');
    const typeSel = document.getElementById('typeSelect');
    const currentType = {{ goodTypeId ?? 'null' }};

    async function loadTypes(catId) {
        typeSel.innerHTML = '<option value="">Все виды</option>';
        if (!catId) return;
        try {
            const res = await fetch(`/api/category/${catId}/types`);
            const types = await res.json();
            types.forEach(t => {
                const o = document.createElement('option');
                o.value = t.id; o.textContent = t.name;
                if (currentType && t.id == currentType) o.selected = true;
                typeSel.appendChild(o);
            });
        } catch {}
    }

    catSel.addEventListener('change', () => loadTypes(catSel.value));
    if (catSel.value) loadTypes(catSel.value);
});
</script>
{% endblock %}
