<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Вход — Административная панель</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center p-4 font-sans text-gray-900">
<div class="bg-white w-full max-w-sm rounded-xl shadow-xl border border-gray-200 overflow-hidden">
    <div class="bg-gradient-to-r from-slate-900 to-slate-800 border-b border-yellow-500/20 p-6 text-center">
        <h1 class="text-2xl font-bold bg-gradient-to-r from-yellow-400 to-yellow-300 bg-clip-text text-transparent">Ломбард</h1>
        <p class="text-sm text-gray-400 mt-1">Панель администратора</p>
    </div>

    <div class="p-6">
        {% if error %}
            <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg p-3 text-sm mb-5 font-medium">
                ⚠ {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('admin_login') }}" class="space-y-4">
            <div>
                <label for="username" class="block text-sm font-bold text-gray-700 mb-1.5 uppercase tracking-wide">Логин</label>
                <input type="text" id="username" name="_username" value="{{ last_username }}" autocomplete="username" autofocus
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent transition">
            </div>

            <div>
                <label for="password" class="block text-sm font-bold text-gray-700 mb-1.5 uppercase tracking-wide">Пароль</label>
                <input type="password" id="password" name="_password" autocomplete="current-password"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent transition">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="w-full mt-2 bg-yellow-600 hover:bg-yellow-500 text-white font-bold py-3 px-4 rounded-lg transition shadow-md uppercase tracking-wide text-sm">
                Войти
            </button>
        </form>

        <a href="{{ path('app_catalog') }}" class="block text-center mt-6 text-sm text-gray-500 hover:text-yellow-600 transition font-medium">
            ← На витрину
        </a>
    </div>

    <div class="bg-slate-50 border-t border-gray-100 p-4 text-center text-xs text-gray-400">
        Только для авторизованных сотрудников
    </div>
</div>
</body>
</html>